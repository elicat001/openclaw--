{
  "name": "@openclaw/wecom",
  "version": "2026.3.3",
  "description": "OpenClaw WeCom (企业微信) channel plugin",
  "type": "module",
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "zod": "^4.3.6"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wecom",
